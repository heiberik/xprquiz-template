# Neon Postgres connection string
# Hent fra https://console.neon.tech → Connection Details
DATABASE_URL=postgresql://...

# OpenRouter API key
# Hent fra https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-...

# Better Auth
# Generer med: openssl rand -base64 32
BETTER_AUTH_SECRET=...
# Lokalt: http://localhost:3000, Prod: https://xprquiz.com
BETTER_AUTH_URL=http://localhost:3000

# Google OAuth (for "Logg inn med Google")
# Hent fra https://console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID=...
GOOGLE_CLIENT_SECRET=...
